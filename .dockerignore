# node_modules is reinstalled inside the `frontend` build stage (see Dockerfile), so it must
# not enter the build context — pnpm's symlinked store also breaks COPY if included.
node_modules

# VCS / editor / local tooling
.git
.gitignore
.vscode
.github
.claude
.pytest_cache

# Build/log artifacts
*.log
npm-debug.log*
pnpm-debug.log*

# Runtime terrain data: both are bind-mounted at runtime and potentially huge — never bake them
# into the image. local_sdf is supplied read-only via a bind mount that would shadow any baked
# copy anyway, so excluding it here avoids ~280 MB of dead weight (it was being copied twice).
splat_cache
local_sdf

# Host-built SPA output: the `frontend` stage rebuilds this fresh, so a stale host copy must not
# enter the context (it would leave dead old asset bundles alongside the freshly built ones).
app/ui
